{
  "name": "react-native-scroll-coordinator",
  "version": "0.1.0-alpha.0",
  "description": "Cross-platform scroll coordinator for collapsible headers, sticky tabs, pagers, and virtualized lists.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuincySx/react-native-scroll-coordinator.git"
  },
  "homepage": "https://github.com/QuincySx/react-native-scroll-coordinator#readme",
  "bugs": {
    "url": "https://github.com/QuincySx/react-native-scroll-coordinator/issues"
  },
  "source": "./src/index.ts",
  "main": "./lib/commonjs/index.web.js",
  "module": "./lib/module/index.web.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.web.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.web.js"
      },
      "default": "./lib/module/index.web.js"
    },
    "./flash-list": {
      "react-native": "./src/flash-list.ts",
      "source": "./src/flash-list.ts",
      "import": {
        "types": "./lib/typescript/module/flash-list.d.ts",
        "default": "./lib/module/flash-list.web.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/flash-list.d.ts",
        "default": "./lib/commonjs/flash-list.web.js"
      },
      "default": "./lib/module/flash-list.web.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "android",
    "ios",
    "docs",
    "flash-list.d.ts",
    "flash-list.js",
    "src",
    "lib",
    "react-native.config.js",
    "react-native-scroll-coordinator.podspec",
    "README.md",
    "LICENSE",
    "!android/build",
    "!android/.gradle",
    "!android/src/test",
    "!**/*.map"
  ],
  "scripts": {
    "build": "bob build",
    "check": "yarn format:check && yarn lint && yarn typecheck && yarn test && yarn test:release && yarn test:tarball && yarn workspace CoordinatorExample test --runInBand && yarn workspace CoordinatorExample build:web",
    "clean": "rm -rf android/build lib",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src tests scripts example/App.tsx example/src example/index.web.tsx example/vite.config.mts",
    "prepublishOnly": "node scripts/verify-publish.mjs && yarn check",
    "prepare": "bob build",
    "test": "node tests/package-contract.test.mjs && node --no-warnings tests/tab-state.test.mjs && node --no-warnings tests/android-pager-state.test.mjs && node --no-warnings tests/header-effect.test.mjs && node tests/cross-platform-adapters.test.mjs && node tests/metro-singleton.test.mjs",
    "test:release": "bob build && node --test tests/release-contract.test.mjs && npm pack --dry-run",
    "test:tarball": "node scripts/test-tarball.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "fabric",
    "android",
    "ios",
    "web",
    "flash-list",
    "coordinator-layout",
    "collapsible-header",
    "sticky-tabs"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@shopify/flash-list": ">=2 <3",
    "react": ">=19 <20",
    "react-native": ">=0.81 <0.82",
    "react-native-collapsible-tab-view": ">=8.0.1 <9",
    "react-native-pager-view": ">=8 <9",
    "react-native-reanimated": ">=3.8.1 <5"
  },
  "peerDependenciesMeta": {
    "@shopify/flash-list": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "author": "Scroll Coordinator contributors",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "workspaces": [
    "example"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/runtime": "^7.29.0",
    "@react-native/eslint-config": "0.81.5",
    "@shopify/flash-list": "2.3.2",
    "@types/react": "^19.1.0",
    "eslint": "^8.57.1",
    "prettier": "2.8.8",
    "react": "19.2.7",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.43.0",
    "react-native-collapsible-tab-view": "8.0.1",
    "react-native-pager-view": "8.0.4",
    "react-native-reanimated": "3.19.4",
    "typescript": "^5.9.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNCoordinatorSpec",
    "type": "components",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName": "com.scrollcoordinator"
    },
    "ios": {
      "componentProvider": {
        "RNCoordinatorHorizontal": "RNCoordinatorHorizontalComponentView"
      }
    }
  },
  "packageManager": "yarn@4.12.0"
}
